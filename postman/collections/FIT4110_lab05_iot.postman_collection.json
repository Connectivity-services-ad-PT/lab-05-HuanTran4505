{
  "info": {
    "_postman_id": "fit4110-lab05-iot-collection",
    "name": "FIT4110 Lab05 IoT Ingestion",
    "description": "Postman/Newman collection để kiểm thử IoT Ingestion API trong môi trường Docker Compose (Lab 05).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has status ok', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});",
              "pm.test('Response has service name', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.service).to.be.a('string');",
              "});",
              "pm.test('Response has version', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.version).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Create Reading – Success (201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has reading_id', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.reading_id).to.be.a('string');",
              "    pm.environment.set('readingId', json.reading_id);",
              "});",
              "pm.test('accepted is true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.accepted).to.eql(true);",
              "});",
              "pm.test('device_id matches', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.device_id).to.eql('ESP32-LAB-A01');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:30:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      }
    },
    {
      "name": "Create Reading – High Temperature (201 + X-Warning header)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('X-Warning header present', function () {",
              "    pm.expect(pm.response.headers.get('X-Warning')).to.eql('high-temperature');",
              "});",
              "pm.test('accepted is true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.accepted).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-B02\",\n  \"metric\": \"temperature\",\n  \"value\": 75,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T09:00:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      }
    },
    {
      "name": "Create Reading – Unauthorized (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 401', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "pm.test('Response is problem+json', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql(401);",
              "    pm.expect(json.title).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 25.0,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:00:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      }
    },
    {
      "name": "Create Reading – Invalid Token (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 401', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "pm.test('detail mentions invalid bearer token', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.detail).to.include('Invalid bearer token');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer wrong-token"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 25.0,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:00:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      }
    },
    {
      "name": "Create Reading – Validation Error (422)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 422', function () {",
              "    pm.response.to.have.status(422);",
              "});",
              "pm.test('Response is problem detail', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql(422);",
              "    pm.expect(json.title).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"AB\",\n  \"metric\": \"unknown-metric\",\n  \"value\": 999,\n  \"timestamp\": \"bad-timestamp\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      }
    },
    {
      "name": "Get Latest Readings (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has items array', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.items).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/latest?limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "latest"],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Get Reading by ID – Not Found (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test('Response is problem detail', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/R-99999999-9999",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "R-99999999-9999"]
        }
      }
    },
    {
      "name": "Get Reading by ID – Success (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('reading_id matches', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.reading_id).to.eql(pm.environment.get('readingId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/{{readingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "{{readingId}}"]
        }
      }
    }
  ]
}
